{
  "name": "@dialectos/providers",
  "version": "0.3.0",
  "description": "Translation providers with strategy pattern, circuit breaker, and retry logic",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && cp src/data/*.json dist/data/ 2>/dev/null || mkdir -p dist/data && cp src/data/*.json dist/data/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@dialectos/security": "workspace:*",
    "@dialectos/types": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "license": "BSL-1.1",
  "author": "Simon Gonzalez <simon@kyanitelabs.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/KyaniteLabs/DialectOS.git"
  },
  "homepage": "https://kyanitelabs.github.io/DialectOS/",
  "bugs": {
    "url": "https://github.com/KyaniteLabs/DialectOS/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "spanish",
    "translation",
    "i18n",
    "providers",
    "dialect",
    "typescript"
  ]
}
