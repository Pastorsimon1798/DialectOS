# DialectOS Docker Compose Environment Example
# Copy to .env and fill in your values before running docker-compose up

# Demo server binding
DIALECTOS_DEMO_HOST=0.0.0.0
DIALECTOS_DEMO_PORT=8080

# LLM provider configuration (optional — demo works without these)
# LLM_API_URL=https://api.openai.com/v1/chat/completions
# LLM_API_FORMAT=openai
# LLM_MODEL=gpt-4o-mini
# LLM_ALLOW_LOCAL=1

# Model for local Ollama setup (used by ollama-pull service)
# DIALECTOS_DEMO_MODEL=qwen3.5-4b
